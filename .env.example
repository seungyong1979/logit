# =====================================================
# Logit Blog — 환경변수 설정 파일
# .env.example을 복사해서 .env로 이름 변경 후 값 입력
# =====================================================

# 앱 기본 설정
APP_NAME=Logit
APP_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production
BASE_URL=https://logit.kr

# PostgreSQL DB (Supabase 또는 Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 관리자 계정 (최초 실행 시 자동 생성)
ADMIN_EMAIL=admin@logit.kr
ADMIN_PASSWORD=your-strong-password-here

# OpenAI API (AI 초안 자동 생성)
OPENAI_API_KEY=sk-...

# AI 글 생성 스케줄 (기본: 매일 새벽 6시 KST)
AI_DRAFT_SCHEDULE_HOUR=6
AI_DRAFT_SCHEDULE_MINUTE=0
AI_DRAFT_TIMEZONE=Asia/Seoul

# 글 생성 설정
AI_MODEL=gpt-4o-mini
AI_DRAFT_CATEGORIES=AI 활용,자동화,생산성,디지털 도구,블로그 운영,수익화 실험,노트/정리법,비교/리뷰

# Google AdSense (승인 후 입력)
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
ADSENSE_SLOT_TOP=XXXXXXXXXX
ADSENSE_SLOT_MID=XXXXXXXXXX
ADSENSE_SLOT_BOTTOM=XXXXXXXXXX
ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX

# Google Analytics (선택)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
